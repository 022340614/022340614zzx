/* pages/detail/detail.wxss */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 加载状态 */
.loading, .error {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
}

.error image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.retry-btn {
  margin-top: 40rpx;
  background-color: #4CAF50;
  color: white;
  border-radius: 8rpx;
  width: 200rpx;
}

/* 内容区域 */
.content {
  padding: 20rpx;
}

/* 头部信息 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.item-type, .item-status {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.item-type.found {
  background: #e8f5e8;
  color: #4CAF50;
}

.item-type.lost {
  background: #fff3e0;
  color: #ff9800;
}

.item-status.active {
  background: #e8f5e8;
  color: #4CAF50;
}

.item-status.completed {
  background: #f0f0f0;
  color: #999;
}

/* 信息区块 */
.section {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

/* 信息行 */
.info-row {
  display: flex;
  margin-bottom: 16rpx;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 160rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 描述 */
.description {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  white-space: pre-wrap;
}

/* 图片展示 */
.image-gallery {
  height: 400rpx;
}

.image-gallery image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

/* 联系方式 */
.contact-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.contact-display {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  text-align: center;
}

.copy-btn {
  background-color: #4CAF50;
  color: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
}

/* 发布者信息 */
.publisher-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid #f0f0f0;
}

.nickname {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.publish-time {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  background-color: #4CAF50;
  color: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
}

.delete-btn {
  background-color: #ff4444;
}

.delete-btn:active {
  background-color: #cc0000;
}

.action-btn:active {
  background-color: #45a049;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .content {
    padding: 10rpx;
  }
  
  .section {
    padding: 20rpx;
  }
  
  .action-buttons {
    flex-direction: column;
  }
}