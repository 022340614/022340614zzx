/* pages/publish/publish.wxss */
.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-group {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: bold;
}

/* 类型选择 */
.type-selector {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  text-align: center;
  transition: all 0.3s;
}

.type-option.active {
  border-color: #4CAF50;
  background-color: #f0f9f0;
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

/* 输入框和选择器 */
.form-input, .form-textarea {
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-input:focus, .form-textarea:focus {
  border-color: #4CAF50;
}

.form-textarea {
  height: 160rpx;
  resize: none;
}

.picker {
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
}

.picker.placeholder {
  color: #999;
}

/* 自定义地点 */
.custom-location {
  margin-top: 20rpx;
}

.custom-location-toggle {
  margin-top: 20rpx;
  color: #4CAF50;
  font-size: 26rpx;
  text-align: center;
  text-decoration: underline;
}

/* 字符计数 */
.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 图片上传 */
.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.upload-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.upload-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  transition: all 0.3s;
}

.upload-btn:active {
  border-color: #4CAF50;
  background-color: #f0f9f0;
}

.upload-btn.disabled {
  opacity: 0.5;
}

.upload-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

/* 提交按钮 */
.form-actions {
  margin-top: 40rpx;
}

.submit-btn {
  background-color: #4CAF50;
  color: white;
  border-radius: 8rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.submit-btn:active {
  background-color: #45a049;
}

.submit-btn[disabled] {
  background-color: #cccccc;
  color: #666666;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .container {
    padding: 20rpx;
  }
  
  .form-group {
    padding: 20rpx;
  }
  
  .type-selector {
    flex-direction: column;
  }
}