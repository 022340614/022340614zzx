<!--pages/detail/detail.wxml-->
<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="error">
    <image src="/images/error.png" mode="aspectFit"></image>
    <text>{{error}}</text>
    <button class="retry-btn" bindtap="loadItem">重试</button>
  </view>

  <!-- 内容区域 -->
  <view wx:else class="content">
    <!-- 头部信息 -->
    <view class="header">
      <view class="item-type {{item.type}}">
        {{item.type === 'found' ? '招领' : '寻物'}}
      </view>
      <view class="item-status {{item.status}}">
        {{item.status === 'active' ? '进行中' : '已结束'}}
      </view>
    </view>

    <!-- 物品信息 -->
    <view class="section">
      <view class="section-title">物品信息</view>
      <view class="info-row">
        <text class="info-label">物品名称：</text>
        <text class="info-value">{{item.name}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">物品分类：</text>
        <text class="info-value">{{item.category}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">时间：</text>
        <text class="info-value">{{item.time}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">地点：</text>
        <text class="info-value">{{item.location}}</text>
      </view>
    </view>

    <!-- 物品描述 -->
    <view class="section" wx:if="{{item.description}}">
      <view class="section-title">详细描述</view>
      <view class="description">{{item.description}}</view>
    </view>

    <!-- 图片展示 -->
    <view class="section" wx:if="{{item.images && item.images.length > 0}}">
      <view class="section-title">图片</view>
      <view class="image-gallery">
        <swiper 
          indicator-dots="{{item.images.length > 1}}"
          indicator-color="rgba(0,0,0,.3)"
          indicator-active-color="#4CAF50"
          autoplay="{{item.images.length > 1}}"
          interval="3000"
        >
          <swiper-item wx:for="{{item.images}}" wx:key="*this">
            <image 
              src="{{item}}" 
              mode="aspectFit" 
              bindtap="previewImage"
              data-index="{{index}}"
            ></image>
          </swiper-item>
        </swiper>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="section">
      <view class="section-title">联系方式</view>
      <view class="contact-info">
        <text class="contact-display">{{item.contactDisplay}}</text>
        <button 
          class="copy-btn" 
          bindtap="copyContact"
          data-contact="{{item.contact}}"
        >
          复制联系方式
        </button>
      </view>
    </view>

    <!-- 发布者信息 -->
    <view class="section">
      <view class="section-title">发布者</view>
      <view class="publisher-info">
        <image class="avatar" src="{{item.publisher.avatar}}"></image>
        <text class="nickname">{{item.publisher.nickname}}</text>
        <text class="publish-time">发布于 {{item.createTime}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons" wx:if="{{isOwner}}">
      <button 
        class="action-btn" 
        bindtap="toggleStatus"
        wx:if="{{item.status === 'active'}}"
      >
        标记为已解决
      </button>
      <button 
        class="action-btn" 
        bindtap="toggleStatus"
        wx:else
      >
        重新发布
      </button>
      <button 
        class="action-btn delete-btn" 
        bindtap="deleteItem"
      >
        删除信息
      </button>
    </view>
  </view>
</view>