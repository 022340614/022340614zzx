<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-info">
    <image class="avatar" src="{{userInfo.avatarUrl}}"></image>
    <view class="user-details">
      <text class="nickname">{{userInfo.nickName}}</text>
      <text class="welcome">欢迎使用校园失物招领</text>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats">
    <view class="stat-item">
      <text class="stat-number">{{stats.total}}</text>
      <text class="stat-label">总发布</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{stats.active}}</text>
      <text class="stat-label">进行中</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{stats.completed}}</text>
      <text class="stat-label">已解决</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="section-title">我的发布</view>
    <view class="menu-list">
      <view 
        class="menu-item" 
        bindtap="navigateToList"
        data-type="all"
      >
        <text class="menu-icon">📋</text>
        <text class="menu-text">全部发布</text>
        <text class="menu-arrow">›</text>
      </view>
      <view 
        class="menu-item" 
        bindtap="navigateToList"
        data-type="active"
      >
        <text class="menu-icon">⏳</text>
        <text class="menu-text">进行中</text>
        <text class="menu-arrow">›</text>
      </view>
      <view 
        class="menu-item" 
        bindtap="navigateToList"
        data-type="completed"
      >
        <text class="menu-icon">✅</text>
        <text class="menu-text">已解决</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="menu-section">
    <view class="section-title">设置</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="editProfile">
        <text class="menu-icon">✏️</text>
        <text class="menu-text">编辑资料</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="clearCache">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">清除缓存</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="showAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="showHelp">
        <text class="menu-icon">❓</text>
        <text class="menu-text">使用帮助</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="contactUs">
        <text class="menu-icon">📞</text>
        <text class="menu-text">联系我们</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version">
    <text>v1.0.0</text>
  </view>
</view>