/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

/* 全局样式重置 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'Segoe UI', Arial, Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  line-height: 1.6;
}

/* 通用按钮样式 */
button {
  border-radius: 8rpx;
  font-size: 32rpx;
  transition: all 0.3s;
}

button:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 通用输入框样式 */
input, textarea {
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

input:focus, textarea:focus {
  border-color: #4CAF50;
  outline: none;
}

/* 通用卡片样式 */
.card {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 通用标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 10rpx;
}

.tag.found {
  background: #e8f5e8;
  color: #4CAF50;
}

.tag.lost {
  background: #fff3e0;
  color: #ff9800;
}

.tag.active {
  background: #e8f5e8;
  color: #4CAF50;
}

.tag.completed {
  background: #f0f0f0;
  color: #999;
}

/* 通用加载样式 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.loading::before {
  content: "⏳";
  display: block;
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

/* 通用错误样式 */
.error {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.error::before {
  content: "❌";
  display: block;
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

/* 通用空状态样式 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty::before {
  content: "📭";
  display: block;
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

/* 响应式布局 */
@media (max-width: 750rpx) {
  .card {
    padding: 20rpx;
    margin-bottom: 10rpx;
  }
  
  input, textarea {
    padding: 16rpx;
    font-size: 26rpx;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}